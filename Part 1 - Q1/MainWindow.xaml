<Window x:Class="AutomationMonitor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AutomationMonitor"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">

            <Grid Margin="15">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Machine Status -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                    <TextBlock Text="Machine Status: " 
                       FontSize="16" 
                       FontWeight="Bold"/>
                    <TextBlock x:Name="StatusText" 
                       FontSize="16"
                       FontWeight="Bold"
                       Foreground="Blue"/>
                </StackPanel>

                <!-- Control Buttons -->
                <StackPanel Orientation="Horizontal" Grid.Row="1" Margin="0,0,0,15">
                    <Button Content="Start" Width="80" Margin="5" Click="Start_Click"/>
                    <Button Content="Stop" Width="80" Margin="5" Click="Stop_Click"/>
                    <Button Content="Reset" Width="80" Margin="5" Click="Reset_Click"/>
                </StackPanel>

                <!-- Simulated I/O -->
                <GroupBox Header="I/O Signals" Grid.Row="2" Margin="0,0,0,15">
                    <StackPanel Margin="10">
                        <TextBlock x:Name="SensorText" FontSize="14"/>
                        <TextBlock x:Name="MotorText" FontSize="14"/>
                    </StackPanel>
                </GroupBox>

                <!-- Event Log -->
                <GroupBox Header="Event Log" Grid.Row="3">
                    <ListBox x:Name="EventLog"/>
                </GroupBox>

    </Grid>
</Window>
