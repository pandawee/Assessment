<Window x:Class="_1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Machine Status Monitor"
        Height="450" Width="800">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Machine Status Section -->
        <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
            <TextBlock Text="Machine Status: "
                       FontSize="16"
                       FontWeight="Bold"/>

            <TextBlock x:Name="StatusText"
                       FontSize="16"
                       FontWeight="Bold"
                       Margin="5,0,0,0"
                       Foreground="Blue"/>

            <!-- Status Indicator Circle -->
            <Ellipse x:Name="StatusIndicator"
                     Width="20"
                     Height="20"
                     Margin="10,0,0,0"
                     Fill="Blue"/>
        </StackPanel>

        <!-- Control Buttons -->
        <StackPanel Orientation="Horizontal" Grid.Row="1" Margin="0,0,0,15">

            <Button Content="Start"
                    Width="80"
                    Margin="5"
                    Click="Start_Click"/>

            <Button Content="Stop"
                    Width="80"
                    Margin="5"
                    Click="Stop_Click"/>

            <Button Content="Reset"
                    Width="80"
                    Margin="5"
                    Click="Reset_Click"/>

            <!-- Emergency Stop -->
            <Button Content="Emergency Stop"
                    Width="130"
                    Margin="5"
                    Background="Red"
                    Foreground="White"
                    Click="Emergency_Click"/>
        </StackPanel>

        <!-- Simulated I/O -->
        <GroupBox Header="I/O Signals" Grid.Row="2" Margin="0,0,0,15">
            <StackPanel Margin="10">
                <TextBlock x:Name="SensorText"
                           FontSize="14"
                           FontWeight="SemiBold"/>
                <TextBlock x:Name="MotorText"
                           FontSize="14"
                           FontWeight="SemiBold"/>
            </StackPanel>
        </GroupBox>

        <!-- Event Log -->
        <GroupBox Header="Event Log" Grid.Row="3">
            <ListBox x:Name="EventLog"/>
        </GroupBox>

    </Grid>
</Window>
